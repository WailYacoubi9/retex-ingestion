# Copier en .env et ajuster si besoin.
# Valeurs par defaut = backbone lance en local (ports exposes sur localhost).
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=retex_dev_pwd
QDRANT_URL=http://localhost:6333
